{
  "name": "@aegisprotocol/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Aegis Protocol AI Agent Skill Marketplace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": ["aegis", "ai-agents", "mcp", "solana", "marketplace", "sdk"],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
