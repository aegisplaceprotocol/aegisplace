{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://aegis-backend.onrender.com/api/$1"
    },
    {
      "source": "/metrics",
      "destination": "https://aegis-backend.onrender.com/metrics"
    },
    {
      "source": "/.well-known/agent.json",
      "destination": "https://aegis-backend.onrender.com/.well-known/agent.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
