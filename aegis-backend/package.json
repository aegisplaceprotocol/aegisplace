{
  "name": "aegis-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/_core/index.ts",
    "build": "esbuild src/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --alias:@shared=../shared",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "seed:real": "tsx scripts/seed-real-operators.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@trpc/server": "^11.6.0",
    "bs58": "^6.0.0",
    "cookie": "^1.0.2",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jose": "6.1.0",
    "mongoose": "^9.3.3",
    "nanoid": "^5.1.5",
    "pino": "^10.3.1",
    "superjson": "^1.13.3",
    "tweetnacl": "^1.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@types/chai": "^5.2.3",
    "@types/express": "4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.12.0",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "5.9.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.4"
  }
}
