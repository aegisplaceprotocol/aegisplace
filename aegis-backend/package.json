{
  "name": "aegis-backend",
  "version": "1.0.0",
  "type": "module",
  "author": "Aegis Protocol <team@aegisplace.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/_core/index.ts",
    "build": "esbuild src/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run --config vitest.config.ts",
    "seed:real": "tsx scripts/seed-real-operators.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@trpc/server": "^11.6.0",
    "cookie": "^1.0.2",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jose": "6.1.0",
    "mongoose": "^9.3.3",
    "nanoid": "^5.1.5",
    "pino": "^10.3.1",
    "superjson": "^1.13.3",
    "tweetnacl": "^1.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "^24.12.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.1",
    "typescript": "5.9.3",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    },
    "onlyBuiltDependencies": [
      "bigint-buffer",
      "bufferutil",
      "esbuild",
      "utf-8-validate"
    ]
  }
}
