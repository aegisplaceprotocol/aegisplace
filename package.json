{
  "name": "aegis-workspace",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "install:frontend": "pnpm install --filter aegis-frontend",
    "install:backend": "pnpm install --filter aegis-backend",
    "install:apps": "pnpm install --filter aegis-frontend --filter aegis-backend",
    "dev:frontend": "pnpm --filter aegis-frontend run dev",
    "dev:backend": "pnpm --filter aegis-backend run dev",
    "dev": "pnpm -r --parallel --filter aegis-frontend --filter aegis-backend run dev",
    "build:frontend": "pnpm --filter aegis-frontend run build",
    "build:backend": "pnpm --filter aegis-backend run build",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "start:backend": "pnpm --filter aegis-backend run start",
    "preview:frontend": "pnpm --filter aegis-frontend run preview"
  },
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    }
  }
}
