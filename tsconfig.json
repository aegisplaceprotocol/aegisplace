{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2015"],
    "module": "commonjs",
    "target": "es6",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["aegis-frontend/src/*"],
      "@shared/*": ["aegis-backend/shared/*", "aegis-frontend/shared/*"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    },
    "esm": false
  },
  "include": ["aegis-backend/src/**/*.ts", "aegis-backend/shared/**/*.ts", "aegis-frontend/src/**/*.ts", "aegis-frontend/shared/**/*.ts", "tests/**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules"]
}
